{
  "projectName": "My App Screenshots",
  "baseUrl": "http://localhost:3000/",
  "outputDir": "output/social",
  "browser": "chromium",
  "waitUntil": "load",
  "crawl": {
    "enabled": true,
    "maxPages": 40,
    "maxDepth": 4,
    "sameOrigin": true,
    "includeQuery": false,
    "waitAfterLoadMs": 200,
    "excludePatterns": [
      "/logout",
      "/signout"
    ],
    "viewports": [
      { "name": "desktop-full", "width": 1440, "height": 1800, "fullPage": true },
      { "name": "social-1200x627", "width": 1200, "height": 627, "fullPage": false },
      { "name": "mobile", "width": 430, "height": 932, "fullPage": false }
    ]
  }
}
