{
  "projectName": "My App Full Workflow",
  "baseUrl": "http://localhost:3000/",
  "outputDir": "output/workflow-recorder",
  "browser": "chromium",
  "browserChannel": "auto",
  "headless": true,
  "waitUntil": "domcontentloaded",
  "viewport": {
    "width": 1512,
    "height": 982
  },
  "recording": {
    "width": 1920,
    "height": 1080,
    "keepRawVideo": false
  },
  "crawl": {
    "enabled": true,
    "maxPages": 35,
    "maxDepth": 4,
    "sameOrigin": true,
    "includeQuery": false,
    "waitAfterLoadMs": 500,
    "excludePatterns": [
      "/logout",
      "/signout",
      "/sign-out",
      "/delete",
      "/remove",
      "/destroy"
    ]
  },
  "workflow": {
    "enabled": true,
    "includeHoverSweep": true,
    "scrollPerPage": true,
    "scrollSteps": 4,
    "perPagePauseMs": 500,
    "actionPauseMs": 450,
    "interactionLimitPerPage": 6,
    "allowRiskyActions": false
  },
  "setupSteps": [
    { "type": "wait", "ms": 400 }
  ]
}
